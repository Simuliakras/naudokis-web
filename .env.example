# Naudokis web — environment variables. Copy to .env.local for local dev.
# Everything here is optional; the build runs against prod defaults if unset.

# Backend REST API base URL. Defaults to production so a misconfigured build
# never silently hits dev. Point at dev locally: https://api-dev.naudokis.lt
# NEXT_PUBLIC_API_BASE_URL=https://api.naudokis.lt

# Google Maps Embed API key for the listing-detail map. No key -> the map falls
# back to the decorative delivery-zone graphic (fine for local dev/screenshots).
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Sentry error monitoring. No DSN -> Sentry no-ops (fine for local dev).
# NEXT_PUBLIC_SENTRY_DSN=
# Used by the build to upload source maps; CI/deploy only, never commit a real one.
# SENTRY_AUTH_TOKEN=

# Plausible analytics (cookieless). No domain -> the script is not loaded.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=naudokis.lt
# Override only if self-hosting Plausible.
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Android App Links. Required before launch: paste the Play Console App signing
# SHA-256 and Upload key SHA-256 fingerprints, comma/newline/semicolon separated.
# ANDROID_APP_LINK_SHA256_CERT_FINGERPRINTS=AB:CD:...,12:34:...
