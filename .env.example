# Naudokis web — environment variables. Copy to .env.local for local dev.
# Everything here is optional; the build runs against prod defaults if unset.

# Backend REST API base URL. Defaults to production so a misconfigured build
# never silently hits dev. Point at dev locally: https://api-dev.naudokis.lt
# NEXT_PUBLIC_API_BASE_URL=https://api.naudokis.lt

# Google Maps Embed API key for the listing-detail map. No key -> the map falls
# back to the decorative delivery-zone graphic (fine for local dev/screenshots).
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Sentry error monitoring. No DSN -> Sentry no-ops (fine for local dev).
# NEXT_PUBLIC_SENTRY_DSN=
# Used by the build to upload source maps; CI/deploy only, never commit a real one.
# SENTRY_AUTH_TOKEN=

# Plausible analytics (cookieless). No domain -> the script is not loaded.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=naudokis.lt
# Override only if self-hosting Plausible.
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
# Optional Events API override for server-side /go outcome measurement.
# PLAUSIBLE_EVENTS_API=https://plausible.io/api/event

# iOS Team ID + bundle identifier. This value is public and must match the AASA.
APPLE_APP_ID=U2NZQ56A8W.com.naudokislt.naudokis

# Android App Links. Required before launch: SHA-256 certificate fingerprints,
# comma/newline/semicolon separated. Include every certificate that signs an
# INSTALLABLE release — the Play app-signing certificate, plus any active
# signing-key rotation certificate. Do NOT add the upload certificate: it does not
# sign Play-distributed APKs, and publishing it only widens what can claim these
# links. See public/.well-known/README.md.
# ANDROID_APP_LINK_SHA256_CERT_FINGERPRINTS=AB:CD:...
ANDROID_APP_LINK_PACKAGE_NAME=com.naudokis.naudokis

# Number of reverse proxies WE control in front of the app (1 for a single CDN or
# load balancer). This is how the API rate limiter finds the real client address:
# X-Forwarded-For is appended to by each hop, so only the right-most entries are
# trustworthy. Unset/0 means the header is not trusted at all and per-client rate
# limiting is disabled (routes fall back to a global backstop) — set this to the
# real hop count once the hosting platform is chosen.
# TRUSTED_PROXY_HOPS=1

# AppsFlyer OneLink template base for the /invite referral links and the /go smart
# install link. No value -> install links degrade to the /go OS-sniff redirect.
# Live branded-domain template: https://link.naudokis.lt/LNBm (custom OneLink
# subdomain; AppsFlyer hosts its SSL + .well-known association files). Set the real
# value in the prod build env — NEXT_PUBLIC_* is inlined at build time, so a rebuild
# is required. Left commented so local/dev builds stay on the /go fallback by default.
# NEXT_PUBLIC_ONELINK_URL=https://link.naudokis.lt/LNBm
# Server-only HMAC key (32+ random characters). /go puts a signed journey token
# into OneLink deep_link_sub10; signed apps POST it to /api/handoff-event after
# native open/booking/listing intent so web-to-app completion is measurable.
# HANDOFF_SIGNING_SECRET=
