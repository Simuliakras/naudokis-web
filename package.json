{
  "name": "naudokis-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format:css": "prettier --write \"app/**/*.css\"",
    "format:css:check": "prettier --check \"app/**/*.css\"",
    "type-check": "next typegen && tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "responsive:audit": "node scripts/responsive-audit.mjs",
    "responsive:audit:quick": "node scripts/responsive-audit.mjs --quick",
    "legal:json": "node scripts/legal-md-to-json.mjs",
    "legal:shots": "node scripts/legal-audit-shots.mjs",
    "gen:qr": "node scripts/generate-install-qr.mjs",
    "gen:favicon": "node scripts/generate-favicon.mjs",
    "verify:app-links": "node scripts/verify-app-links.mjs",
    "verify:app-links:static": "node scripts/verify-app-links.mjs --static",
    "verify:breakpoints": "node scripts/verify-breakpoints.mjs",
    "verify:release": "yarn verify:breakpoints && node scripts/verify-release.mjs"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.65.0",
    "@tanstack/react-query": "^5.100.14",
    "lucide-react": "^1.21.0",
    "next": "16.2.10",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "resolutions": {
    "postcss": "8.5.19"
  }
}
